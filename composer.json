{
    "name": "ekumanov/flarum-ext-cls-fix",
    "description": "Reserves layout space for inline images in posts to eliminate Cumulative Layout Shift (CLS).",
    "keywords": [
        "flarum",
        "extension",
        "cls",
        "performance",
        "images"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "require": {
        "flarum/core": "^2.0@beta",
        "php": "^8.2"
    },
    "authors": [
        {
            "name": "ekumanov",
            "email": "ekumanov@users.noreply.github.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Ekumanov\\ClsFix\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "CLS Fix",
            "category": "feature",
            "icon": {
                "name": "fas fa-image",
                "backgroundColor": "#4A90D9",
                "color": "#fff"
            }
        }
    }
}
